APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Set by run.sh for this server. Default below so composer/artisan work before run.sh.
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=email2s3
DB_USERNAME=email2s3
DB_PASSWORD=secret

BROADCAST_DRIVER=reverb
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadminpassword
MINIO_ENDPOINT=http://minio:9000
# Set by run.sh (same host as APP_URL, port 9000). Leave empty.
MINIO_PUBLIC_ENDPOINT=
MINIO_BUCKET=email2s3

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
# Use a non-guest user so RabbitMQ accepts connections from Docker (guest is limited to localhost).
RABBITMQ_USER=email2s3
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=/

# PHP memory_limit for migration worker (large email bodies/attachments). Default 256M.
# MIGRATION_WORKER_MEMORY_LIMIT=256M

REVERB_APP_ID=email2s3-app
REVERB_APP_KEY=email2s3-key
REVERB_APP_SECRET=email2s3-secret
# Set by run.sh (same host as APP_URL). Default so app works before run.sh.
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
